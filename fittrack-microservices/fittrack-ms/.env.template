# FitTrack Microservices — Environment Variables
# Copy this file to .env and fill in your values

# Required: Your Anthropic API key for AI suggestions
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# JWT secret — change this in production!
JWT_SECRET=fittrack-jwt-secret-key-microservices-v3-2026-change-in-prod

# MySQL root password for all databases
MYSQL_ROOT_PASSWORD=root
